            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();\r",
                  "\r",
                  "if (!json.token) {\r",
                  "    console.error(\"Setup 1 failed — token not found\");\r",
                  "    return;\r",
                  "}\r",
                  "\r",
                  "pm.environment.set(\"token\", json.token);\r",
                  "console.log(\"Setup 1 complete — token saved:\", json.token);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
